{
  "multipart": [
    {
      "when": {
        "axis": "x",
        "facing": "north"
      },
      "apply": {
        "model": "pod_racing_addon:block/pod_stabilizer"
      }
    },
    {
      "when": {
        "axis": "x",
        "facing": "up"
      },
      "apply": {
        "model": "pod_racing_addon:block/pod_stabilizer",
        "x": 90
      }
    },
    {
      "when": {
        "axis": "x",
        "facing": "south"
      },
      "apply": {
        "model": "pod_racing_addon:block/pod_stabilizer",
        "x": 180
      }
    },
    {
      "when": {
        "axis": "x",
        "facing": "down"
      },
      "apply": {
        "model": "pod_racing_addon:block/pod_stabilizer",
        "x": 270
      }
    },

    {
      "when": {
        "axis": "z",
        "facing": "east"
      },
      "apply": {
        "model": "pod_racing_addon:block/pod_stabilizer",
        "y": 90
      }
    },
    {
      "when": {
        "axis": "z",
        "facing": "up"
      },
      "apply": {
        "model": "pod_racing_addon:block/pod_stabilizer",
        "x": 90,
        "y": 90
      }
    },
    {
      "when": {
        "axis": "z",
        "facing": "west"
      },
      "apply": {
        "model": "pod_racing_addon:block/pod_stabilizer",
        "y": 270
      }
    },
    {
      "when": {
        "axis": "z",
        "facing": "down"
      },
      "apply": {
        "model": "pod_racing_addon:block/pod_stabilizer",
        "x": 270,
        "y": 90
      }
    },

    {
      "when": {
        "axis": "y",
        "facing": "north"
      },
      "apply": {
        "model": "pod_racing_addon:block/pod_stabilizer",
        "x": 90
      }
    },
    {
      "when": {
        "axis": "y",
        "facing": "east"
      },
      "apply": {
        "model": "pod_racing_addon:block/pod_stabilizer",
        "x": 90,
        "y": 90
      }
    },
    {
      "when": {
        "axis": "y",
        "facing": "south"
      },
      "apply": {
        "model": "pod_racing_addon:block/pod_stabilizer",
        "x": 90,
        "y": 180
      }
    },
    {
      "when": {
        "axis": "y",
        "facing": "west"
      },
      "apply": {
        "model": "pod_racing_addon:block/pod_stabilizer",
        "x": 90,
        "y": 270
      }
    }
  ]
}